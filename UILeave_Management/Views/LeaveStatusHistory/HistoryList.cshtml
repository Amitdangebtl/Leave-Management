@model List<UILeave_Management.Models.LeaveStatusHistory>

<div class="container mt-4">
    <h2 class="text-center">Leave Status History</h2>

    @if (Model != null && Model.Count > 0)
    {
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>HistoryId</th>
                    <th>LeaveId</th>
                    <th>UpdatedBy</th>
                    <th>OldStatus</th>
                    <th>NewStatus</th>
                    <th>UpdatedOn</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    <tr>
                        <td>@Model[i].HistoryId</td>
                        <td>@Model[i].LeaveId</td>
                        <td>@Model[i].UpdatedBy</td>
                        <td>@Model[i].OldStatus</td>
                        <td>@Model[i].NewStatus</td>
                        <td>@Model[i].UpdatedOn</td>
                        <td>
                            <a href="/LeaveStatusHistoryMVC/HistoryDetailView?historyId=@Model[i].HistoryId" class="btn btn-secondary btn-sm">View</a>
                            <a href="/LeaveStatusHistoryMVC/DeleteHistory?historyId=@Model[i].HistoryId" class="btn btn-danger btn-sm">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <h4 class="text-center text-danger">No History Found ❗</h4>
    }

    <a href="/LeaveStatusHistoryMVC/AddHistoryView" class="btn btn-success">Add History</a>
</div>

@if (TempData["Msg"] != null)
{
    <script>alert('@TempData["Msg"]');</script>
}
