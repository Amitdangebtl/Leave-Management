@model UILeave_Management.Models.LeaveStatusHistory

<div class="container mt-5" style="width:420px;">
    <h3 class="text-center">History Detail</h3>

    @if (Model != null)
    {
        <div class="card p-3 shadow-sm rounded-3">
            <p><b>History ID:</b> @Model.HistoryId</p>
            <p><b>Leave ID:</b> @Model.LeaveId</p>
            <p><b>Updated By:</b> @Model.UpdatedBy</p>
            <p><b>Old Status:</b> @Model.OldStatus</p>
            <p><b>New Status:</b> @Model.NewStatus</p>
            <p><b>Updated On:</b> @Model.UpdatedOn</p>

            <a href="/LeaveStatusHistoryMVC/HistoryListView" class="btn btn-primary w-100 mt-2">Back</a>
        </div>
    }
    else
    {
        <div class="alert alert-danger">History Not Found ❗</div>
    }
</div>
