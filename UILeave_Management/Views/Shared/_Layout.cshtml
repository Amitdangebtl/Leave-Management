<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Leave Management</title>

    <!-- Bootstrap + Custom CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        .navbar-brand {
            font-weight: 700;
            font-size: 22px;
            color: #0A1F44 !important;
        }

        .nav-link {
            font-weight: 500;
            margin-right: 12px;
            transition: 0.3s;
        }

            .nav-link:hover {
                color: #0A1F44 !important;
                transform: translateY(-2px);
            }

        .auth-btn {
            background: #0A1F44;
            color: white;
            padding: 6px 15px;
            border-radius: 8px;
            font-weight: 600;
            margin-left: 10px;
            transition: 0.3s;
            border: none;
        }

            .auth-btn:hover {
                background: #112D6B;
                transform: scale(1.05);
            }

        footer {
            background: #f8f9fa;
            padding: 12px 0;
            font-size: 15px;
        }
    </style>
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-4">
            <div class="container-fluid px-4">

                <!-- Brand -->
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">Leave Management</a>

                <!-- Mobile Toggle -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Navbar Items -->
                <div class="collapse navbar-collapse" id="navMenu">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer class="border-top text-muted text-center">
        <div class="container">
            &copy; 2026 - <b class="text-dark">Leave Management System</b> |
            <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Privacy Policy</a>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
