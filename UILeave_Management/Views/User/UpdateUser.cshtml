@model UILeave_Management.Models.User

<div class="container mt-5" style="width:400px;">
    <h2 class="text-center">Update User</h2>

    @if (ViewBag.Msg != null)
    {
        <div class="alert alert-warning text-center">@ViewBag.Msg</div>
    }

    <form method="post" action="/UserMVC/UpdateUser">
        <input type="hidden" name="UserId" value="@ViewBag.UserId" />

        <input type="text" name="Name" placeholder="Enter New Name" class="form-control mb-3" required />
        <input type="email" name="Email" placeholder="Enter New Email" class="form-control mb-3" required />
        <input type="password" name="Password" placeholder="Enter New Password" class="form-control mb-3" required />
        <input type="text" name="Role" placeholder="Enter New Role" class="form-control mb-3" required />

        <button class="btn btn-dark w-100">Update</button>
    </form>
</div>
