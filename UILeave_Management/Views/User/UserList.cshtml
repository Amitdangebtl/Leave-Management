@model List<UILeave_Management.Models.User>

<div class="container mt-4">
    <h2 class="text-center">User List</h2>

    @if (Model != null && Model.Count > 0)
    {
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>UserId</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    <tr>
                        <td>@Model[i].UserId</td>
                        <td>@Model[i].Name</td>
                        <td>@Model[i].Email</td>
                        <td>@Model[i].Role</td>
                        <td>
                            <a href="/UserMVC/UpdateUserView?id=@Model[i].UserId" class="btn btn-warning btn-sm">Edit</a>
                            <a href="/UserMVC/DeleteUser?id=@Model[i].UserId" class="btn btn-danger btn-sm">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <h4 class="text-center text-danger">No Users Found ❗</h4>
    }

    <a href="/UserMVC/AddUserView" class="btn btn-success">Add User</a>
</div>
